# ══════════════════════════════════════════════════════════════
# Chocolates Helena — Backend Python (.env.example)
# Copia este archivo como .env y completa los valores reales.
# NUNCA subas el .env real a GitHub.
# ══════════════════════════════════════════════════════════════

# ── Google Gemini API ─────────────────────────────────────────
# Obtener en: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=TU_GEMINI_API_KEY_AQUI

# ── LangSmith (Trazabilidad y Monitoreo) ─────────────────────
# Obtener en: https://smith.langchain.com → Settings → API Keys
LANGCHAIN_API_KEY=lsv2_pt_TU_LANGSMITH_KEY_AQUI
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=chocolates-helena
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com

# ── Servidor ──────────────────────────────────────────────────
PORT=8000

# ── CORS ──────────────────────────────────────────────────────
FRONTEND_ORIGIN=http://localhost:8080
